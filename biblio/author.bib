@ARTICLE{ulen1,
title = {On the method and results of calculation of vibrational tetrahedral sub-level energies and resonance interactions in vibrational spectra of high symmetry molecules: CH4 and GeH4 as an application of the XY4 (Td) molecule},
journal = {Spectrochimica Acta Part A: Molecular and Biomolecular Spectroscopy},
volume = {284},
pages = {121796},
year = {2023},
issn = {1386-1425},
doi = {https://doi.org/10.1016/j.saa.2022.121796},
url = {https://www.sciencedirect.com/science/article/pii/S138614252200943X},
author = {O.N. Ulenikov and E.S. Bekhtereva and O.V. Gromova and A.L. Fomchenko and N.I. Nikolaeva and P.A. Glushkov and S. Bauerecker},
keywords = {Tetrahedral splittings and resonance interactions in spherical top molecules, Vibrational energies of CH up to 12000 cm-1, Precise vibrational parameters of GeH},
abstract = {We report here the analytical description of one of the important problems in the study of XY4 (Td) molecules, namely, description of vibrational tetrahedral sub-level structures and resonance interactions caused by the high symmetry of a molecule. The results obtained are applied to description of the vibrational energy spectrum of the CH4 and GeH4 molecules.}
}

@ARTICLE{ulen2,
title = {Analytical presentation of symmetrized vibrational functions of high symmetry molecules for applications in molecular spectroscopy and chemical physics: Accurate prediction of the vibrational spectrum of GeH4 up to 8000 cm-1 as a relevant application example},
journal = {Journal of Quantitative Spectroscopy and Radiative Transfer},
volume = {321},
pages = {108997},
year = {2024},
issn = {0022-4073},
doi = {https://doi.org/10.1016/j.jqsrt.2024.108997},
url = {https://www.sciencedirect.com/science/article/pii/S0022407324001043},
author = {Oleg N. Ulenikov and Elena S. Bekhtereva and Olga V. Gromova and Anna L. Fomchenko and Petr A. Glushkov and Sigurd Bauerecker},
keywords = {Analytical presentation of vibrational symmetrized wave functions, Spherical top molecules, Vibrational energies of GeH},
abstract = {We report here the analytical description of vibrational wave functions being most important for applications in quantum mechanics, molecular and chemical physics as applied to the high symmetry XY4 (Td) molecules. A general method is discussed and, for the first time, all vibrational functions of such molecule type are presented in an analytical and symmetrized form for all polyads up to the polyad number N=4. To illustrate the relevant application of the derived results, an accurate prediction of all vibrational band centers up to 8000 cm-1 is made for five stable isotopologues MGeH4 (M=76,74,73,72,70) of the germane molecule.}
}